rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Ephemeral cross-device game sessions, keyed by a 6-digit code.
    // This app has no authentication, so access is scoped by path + document
    // shape rather than per-user ownership. The open `delete` grant is REQUIRED:
    // the desktop host best-effort-deletes its own session doc on beforeunload
    // (network.js), and without auth there is no way to distinguish the host from
    // anyone else. Accepted risk: any client who guesses/enumerates an active code
    // can read, steer, or delete that session (griefing only — no user data at
    // stake). Mitigations: Firestore TTL on lastActivity + a billing budget alert
    // (console-side). If Anonymous Auth is added later, store an ownerId on create
    // and require request.auth.uid == ownerId here.
    match /sessions/{code} {
      function validShape() {
        return request.resource.data.keys().hasOnly(
          ['created', 'connected', 'gameState', 'gameAction', 'lastActivity', 'version', 'feedback']
        );
      }

      allow read, delete: if code.matches('^[0-9]{6}$');
      allow create, update: if code.matches('^[0-9]{6}$') && validShape();
    }

    // Public global leaderboard — one row per device id (the doc id). Reads are open so
    // anyone can view the board; writes are shape + range validated and monotonic (a score
    // can only go up). Best-effort only: with no auth, a determined client can still submit
    // a fake in-range score. Real anti-cheat needs server validation / Firebase App Check.
    match /leaderboard/{playerId} {
      function validLeaderboard(data) {
        return data.keys().hasOnly(['name', 'score', 'updatedAt'])
          && data.name is string
          && data.name.size() >= 1 && data.name.size() <= 16
          && data.score is number
          && data.score >= 0 && data.score <= 100000
          && data.updatedAt == request.time;
      }

      allow read: if true;
      allow create: if validLeaderboard(request.resource.data);
      allow update: if validLeaderboard(request.resource.data)
                    && request.resource.data.score >= resource.data.score;
      allow delete: if false;
    }

    // Everything else is denied by default (no other match blocks grant access).
  }
}
