{
  "root": true,
  "env": { "browser": true, "node": true, "es2021": true },
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "script" },
  "extends": "eslint:recommended",
  "globals": {
    "firebase": "readonly",
    "QRious": "readonly"
  },
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "warn",
    "no-empty": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "parserOptions": { "sourceType": "module" }
    }
  ]
}
